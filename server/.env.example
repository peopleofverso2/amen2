PORT=3000
OPENAI_API_KEY=
# Needed for /api/ai/generate-video and /api/ai/generate-video-from-image (Sora models)

# App auth (required for Studio login)
# Set a strong random value in production
AUTH_SESSION_SECRET=
# Optional
# AUTH_COOKIE_NAME=amen_auth
# AUTH_SESSION_TTL_MS=2592000000
# AUTH_COOKIE_SECURE=true

# YouTube OAuth (Google Cloud Console)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/youtube/auth/callback

# Optional: if set, bypasses local token file for refresh token
YOUTUBE_REFRESH_TOKEN=

# Optional: custom path for stored OAuth tokens
# YOUTUBE_TOKEN_PATH=/absolute/path/youtube-oauth.json

# Optional: Firebase Admin verification for Google login in the app
# Minimum: FIREBASE_PROJECT_ID (uses Google ADC on Cloud Run)
# Alternative (local/dev): set FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Optional: persistent media storage on Google Cloud Storage
# If GCS_BUCKET is set, uploaded media/index are synced to this bucket.
GCS_BUCKET=
# Optional prefix/folder inside the bucket (example: amen-prod)
GCS_PREFIX=

# Optional: external ComfyUI backend for Workflow IA
# Examples:
# COMFYUI_BASE_URL=http://127.0.0.1:8188
# COMFYUI_BASE_URL=https://cloud.comfy.org
# COMFYUI_MODE=local   # local | cloud | auto
# COMFYUI_API_PREFIX=  # leave empty for local, /api for Comfy Cloud or reverse proxies
# COMFYUI_API_KEY=     # required for Comfy Cloud or protected reverse proxies
# COMFYUI_WORKFLOW_TEMPLATE_DIR=/absolute/path/to/comfy-workflows
COMFYUI_BASE_URL=
COMFYUI_MODE=auto
COMFYUI_API_PREFIX=
COMFYUI_API_KEY=
COMFYUI_WORKFLOW_TEMPLATE_DIR=
# Export a workflow in "Save (API Format)" from ComfyUI and use placeholders such as:
# __INPUT_IMAGE__, __PROMPT__, __NEGATIVE_PROMPT__, __NOTES__, __HEADLINE__, __BATCH_SIZE__, __OUTPUT_PREFIX__
COMFYUI_THUMBNAIL_PACK_WORKFLOW_PATH=
# Alternative inline JSON (avoid for large templates)
# COMFYUI_THUMBNAIL_PACK_WORKFLOW_JSON=
# Optional request tuning
# COMFYUI_REQUEST_TIMEOUT_MS=30000
# COMFYUI_JOB_TIMEOUT_MS=300000
# COMFYUI_POLL_INTERVAL_MS=2000
